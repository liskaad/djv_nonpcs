# ===================================
# DJV Non-PCs - .gitignore
# ===================================

# =====================================
# FiveM Specific
# =====================================
*.log
*.cache
cache/
*.db
stream/

# =====================================
# Operating System Files
# =====================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# =====================================
# IDEs and Editors
# =====================================

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
*.swp
*.swo

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# =====================================
# Backup and Temporary Files
# =====================================
*.bak
*.backup
*.tmp
*.temp
*.old
*~
temp/
tmp/

# =====================================
# Archives and Compressed Files
# =====================================
*.zip
*.rar
*.7z
*.tar
*.gz

# =====================================
# Node.js (if using any build tools)
# =====================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =====================================
# Environment and Configuration
# =====================================
.env
.env.local
.env.*.local
config.local.lua

# =====================================
# Build and Distribution
# =====================================
dist/
build/
*.dll
*.exe
